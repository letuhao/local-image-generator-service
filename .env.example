# Copy to `.env` and fill in real values.
# Full env surface documented in docs/architecture/image-gen-service.md §5.
# Cycle 0 only uses IMAGEGEN_ENV + MinIO credentials. Later cycles read the rest.

# ── Environment mode ─────────────────────────────────────────────────────────
IMAGEGEN_ENV=dev                           # dev | prod — gates scheme / allowlist / startup assertions

# ── Auth (Cycle 1) ───────────────────────────────────────────────────────────
# Leave blank on purpose — forces the operator to generate real keys before
# the service accepts traffic. Fail-closed pattern consistent with WEBHOOK_*.
# Example: API_KEYS=$(openssl rand -hex 32),$(openssl rand -hex 32)
API_KEYS=                                   # comma-separated generation-scope keys (required)
ADMIN_API_KEYS=                             # comma-separated admin-scope keys (required for fetch/reload)

# ── Logging (Cycle 1) ────────────────────────────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_PROMPTS=false                           # must also be at DEBUG level to actually render prompts

# ── Storage: SQLite job store (Cycle 1) ──────────────────────────────────────
# Inside container; bind-mounted from ./data on host.
# Replace the bind mount with a named volume for prod durability.
DATABASE_PATH=/app/data/jobs.db

# ── ComfyUI (Cycle 2) ────────────────────────────────────────────────────────
COMFYUI_URL=http://comfyui:8188
COMFYUI_WS_URL=ws://comfyui:8188/ws

# ── Storage (Cycle 3) ────────────────────────────────────────────────────────
S3_INTERNAL_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://minio:9000       # override in prod to the public-facing URL
S3_BUCKET=image-gen
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Generation budget (Cycle 7) ──────────────────────────────────────────────
VRAM_BUDGET_GB=12

# ── Civitai fetch (Cycle 6) ──────────────────────────────────────────────────
CIVITAI_API_TOKEN=

# ── Async mode (Cycle 8) ─────────────────────────────────────────────────────
ASYNC_MODE_ENABLED=false                   # flip to true only after LoreWeave adapter handles 202+poll

# ── Webhook dispatcher (Cycle 9) ─────────────────────────────────────────────
WEBHOOK_SIGNING_SECRETS=                   # comma-separated; first entry is active signer
WEBHOOK_ALLOWED_HOSTS=                     # unset = deny-all (fail-closed). e.g. "loreweave.internal"
WEBHOOK_ALLOW_ANY_HOST=false               # dev-only escape hatch; refused when IMAGEGEN_ENV=prod
WEBHOOK_ALLOW_PRIVATE=false                # dev-only; lets webhooks hit RFC1918/loopback; refused in prod
WEBHOOK_TS_SKEW_S=300                      # receiver-side freshness window (seconds)
WEBHOOK_MAX_IN_FLIGHT=8
WEBHOOK_HTTP_TIMEOUT_S=10

# ── Tunables (most cycles) ───────────────────────────────────────────────────
MAX_QUEUE=20
JOB_TIMEOUT_S=300
SHUTDOWN_GRACE_S=90
ORPHAN_REAPER_TTL=86400                    # 24h
JOB_RECORD_TTL=604800                      # 7d
PRESIGN_TTL_S=3600
LORA_MAX_SIZE_BYTES=2147483648             # 2 GiB
LORA_DIR_MAX_SIZE_GB=60
LORA_MAX_CONCURRENT_FETCHES=1
COMFY_POLL_INTERVAL_MS=1000
COMFY_BOOT_WAIT_S=60
AUDIT_LOG_RETENTION_DAYS=90
